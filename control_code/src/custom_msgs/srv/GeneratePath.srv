# GeneratePath.srv
# 경로계획 노드 서비스
#
# Request:
#   step   : 지그재그 행 간격 (m), 기본 0.4
#   wall_x : 벽까지 거리 (m), 기본 2.5
#
# Response:
#   waypoints      : 페인트 on/off + 속도 포함 상세 웨이포인트
#   path           : nav_msgs/Path (Flight Control Node 직접 사용)
#   waypoint_count : 총 웨이포인트 수
#   success        : 생성 성공 여부
#   message        : 오류 메시지 or 요약

float32 step
float32 wall_x
---
custom_msgs/PaintWaypoint[] waypoints
nav_msgs/Path               path
uint32                      waypoint_count
bool                        success
string                      message
